{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "Copilot": {
    "DefaultSystemPrompt": "You are AiCopilot API assistant.",
    "MaxPromptLength": 2000
  },
  "AiProvider": {
    "Endpoint": "https://example-ai-provider.local",
    "ApiKey": "use-secrets-in-production"
  },
  "AllowedHosts": "*"
}

{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "Copilot": {
    "DefaultSystemPrompt": "You are AiCopilot API assistant.",
    "MaxPromptLength": 2000
  },
  "AiProvider": {
    "Endpoint": "https://example-ai-provider.local",
    "ApiKey": "use-secrets-in-production"
  },
  "PlmApi": {
    "BaseUrl": "http://localhost:5099/"
  },
  "Tenant": {
    "DefaultTenantId": "default"
  },
  "Jwt": {
    "Issuer": "AiCopilot",
    "Audience": "AiCopilotClients",
    "SigningKey": "change-this-signing-key-in-production-12345",
    "ExpirationMinutes": 120
  },
  "Auth": {
    "Users": [
      {
        "Username": "user",
        "Password": "user123!",
        "Role": "User",
        "TenantId": "default"
      },
      {
        "Username": "engineer",
        "Password": "engineer123!",
        "Role": "Engineer",
        "TenantId": "default"
      },
      {
        "Username": "admin",
        "Password": "admin123!",
        "Role": "Admin",
        "TenantId": "default"
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "PlmDatabase": "Host=localhost;Port=5432;Database=aicopilot_plm;Username=postgres;Password=postgres"
  }
}
